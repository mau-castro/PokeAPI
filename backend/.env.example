# Database Configuration
# Opcion recomendada: URL unica de conexion
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/pokedex

# Opcion alternativa (si no usas DATABASE_URL):
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=pokedex
# DB_PORT=3306

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PokéAPI Configuration
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Vertex / Gemini Configuration
VERTEX_API_KEY=your-vertex-or-gemini-api-key
VERTEX_MODEL=gemini-2.5-flash-lite

# Server Configuration
DEBUG=False
